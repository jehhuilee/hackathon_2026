# Backend gateway base URL (REST + WebSocket). Copy to .env to override.
VITE_API_URL=http://localhost:8000

# Interviewer 3D avatar. Served from public/avatars (avaturn.glb / brunette.glb),
# both carry ARKit + Oculus viseme blendshapes. Override with your own if desired.
VITE_AVATAR_URL=/avatars/avaturn.glb

# Azure Speech for TTS voice + viseme lipsync. Put real values in .env.local
# (gitignored). When key/region are empty, the app falls back to free browser TTS.
# VITE_AZURE_KEY=
# VITE_AZURE_REGION=koreacentral
# VITE_AZURE_VOICE=en-US-AvaMultilingualNeural
